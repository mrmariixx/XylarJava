[Desktop Entry]
Version=1.0
Name=@Launcher_DisplayName@
GenericName=Minecraft Launcher
Comment=Manage and launch Minecraft instances with XylarJava
Type=Application
Terminal=false
Exec=@Launcher_APP_BINARY_NAME@ %U
StartupNotify=true
Icon=@Launcher_AppID@
Categories=Game;ActionGame;AdventureGame;Simulation;PackageManager;
Keywords=game;minecraft;mc;launcher;polymc;
StartupWMClass=@Launcher_CommonName@
MimeType=application/zip;application/x-modrinth-modpack+zip;x-scheme-handler/curseforge;x-scheme-handler/xylarjava;x-scheme-handler/@Launcher_APP_BINARY_NAME@;
