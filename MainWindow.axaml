<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:XylarJavaLauncher"
        x:Class="XylarJavaLauncher.MainWindow"
        x:CompileBindings="False"
        Title="XylarJava"
        Width="1520"
        Height="960"
        MinWidth="1200"
        MinHeight="780"
        Background="#091019">

  <Window.Styles>
    <Style Selector="Window">
      <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, Arial"/>
    </Style>

    <Style Selector="TextBlock">
      <Setter Property="Foreground" Value="#F5F5F5"/>
    </Style>

    <Style Selector="TextBlock.epicMuted">
      <Setter Property="Foreground" Value="#A7A7AD"/>
    </Style>

    <Style Selector="TextBlock.epicCaption">
      <Setter Property="Foreground" Value="#7E7E86"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="Border.epicPanel">
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="#2D4158"/>
      <Setter Property="Background" Value="#141F2B"/>
      <Setter Property="Padding" Value="20"/>
      <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <Style Selector="Border.epicContentShell">
      <Setter Property="CornerRadius" Value="16"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="#27415E"/>
      <Setter Property="Background" Value="#101A25"/>
      <Setter Property="ClipToBounds" Value="True"/>
      <Setter Property="Opacity" Value="1"/>
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.32"/>
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Border.epicHero">
      <Setter Property="CornerRadius" Value="14"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="#315173"/>
      <Setter Property="Background">
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
          <GradientStop Color="#132436" Offset="0"/>
          <GradientStop Color="#0D1621" Offset="0.62"/>
          <GradientStop Color="#0A1118" Offset="1"/>
        </LinearGradientBrush>
      </Setter>
      <Setter Property="Padding" Value="28"/>
    </Style>

    <Style Selector="Border.epicMetric">
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="#2F4E73"/>
      <Setter Property="Background" Value="#13202D"/>
      <Setter Property="Padding" Value="12,10"/>
      <Setter Property="MinWidth" Value="128"/>
    </Style>

    <Style Selector="Border.epicQuickAction">
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="#2A455F"/>
      <Setter Property="Background" Value="#101A24"/>
      <Setter Property="Padding" Value="12,10"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.2"/>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Border.epicQuickAction:pointerover">
      <Setter Property="Background" Value="#152332"/>
      <Setter Property="BorderBrush" Value="#4A7BA8"/>
    </Style>

    <Style Selector="Border.epicModRow">
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="#2A2A30"/>
      <Setter Property="Background" Value="#1E1E24"/>
      <Setter Property="Padding" Value="14"/>
      <Setter Property="Margin" Value="0,0,0,10"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.2"/>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Border.epicModRow:pointerover">
      <Setter Property="Background" Value="#2C2C32"/>
      <Setter Property="BorderBrush" Value="#C8C8D0"/>
    </Style>

    <Style Selector="TextBox, ComboBox">
      <Setter Property="Background" Value="#25252C"/>
      <Setter Property="Foreground" Value="#F5F5F5"/>
      <Setter Property="BorderBrush" Value="#3A3A42"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="12,10"/>
      <Setter Property="CornerRadius" Value="8"/>
    </Style>

    <Style Selector="Button.epicPrimary">
      <Setter Property="Background" Value="#E5F7FF"/>
      <Setter Property="Foreground" Value="#091019"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Padding" Value="18,10"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.15"/>
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Button.epicPrimary:pointerover">
      <Setter Property="Background" Value="#FFFFFF"/>
    </Style>

    <Style Selector="Button.epicSecondary">
      <Setter Property="Background" Value="#142130"/>
      <Setter Property="Foreground" Value="#F5F5F5"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Padding" Value="18,10"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.15"/>
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Button.epicSecondary:pointerover">
      <Setter Property="Background" Value="#1A2A3C"/>
    </Style>

    <Style Selector="Button.epicMicrosoft">
      <Setter Property="Background" Value="#1DBDDE"/>
      <Setter Property="Foreground" Value="#FFFFFF"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Padding" Value="18,10"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="BorderBrush" Value="#4EE4FF"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.15"/>
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Button.epicMicrosoft:pointerover">
      <Setter Property="Background" Value="#31D0EE"/>
    </Style>

    <Style Selector="Button.epicCompact">
      <Setter Property="Background" Value="#D0D0D8"/>
      <Setter Property="Foreground" Value="#141418"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Padding" Value="14,8"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="MinWidth" Value="88"/>
    </Style>

    <Style Selector="Button.epicCompact:pointerover">
      <Setter Property="Background" Value="#E2E2E8"/>
    </Style>

    <Style Selector="Button.epicGhost">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#C8C8D0"/>
      <Setter Property="BorderBrush" Value="#33506F"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="14,8"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="MinWidth" Value="100"/>
    </Style>

    <Style Selector="ToggleButton.epicNav">
      <Setter Property="Background" Value="#101B27"/>
      <Setter Property="Foreground" Value="#C7D5E2"/>
      <Setter Property="BorderBrush" Value="#1C3146"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
      <Setter Property="Padding" Value="18,16"/>
      <Setter Property="CornerRadius" Value="16"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.2"/>
          <BrushTransition Property="Foreground" Duration="0:0:0.2"/>
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="ToggleButton.epicNav:pointerover">
      <Setter Property="Background" Value="#16283A"/>
      <Setter Property="Foreground" Value="#FFFFFF"/>
      <Setter Property="BorderBrush" Value="#3F6A95"/>
    </Style>

    <Style Selector="ToggleButton.epicNav:checked">
      <Setter Property="Background" Value="#18314A"/>
      <Setter Property="Foreground" Value="#FFFFFF"/>
      <Setter Property="BorderBrush" Value="#77DFFF"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style Selector="ToggleButton.epicFilter">
      <Setter Property="Background" Value="#25252C"/>
      <Setter Property="Foreground" Value="#A7A7AD"/>
      <Setter Property="BorderBrush" Value="#3A3A42"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="14,8"/>
      <Setter Property="CornerRadius" Value="6"/>
    </Style>

    <Style Selector="ToggleButton.epicFilter:checked">
      <Setter Property="Background" Value="#3A3A42"/>
      <Setter Property="Foreground" Value="#FFFFFF"/>
      <Setter Property="BorderBrush" Value="#B8B8C0"/>
    </Style>

    <Style Selector="Border.contentCard">
      <Setter Property="CornerRadius" Value="18"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="#294866"/>
      <Setter Property="Background" Value="#101A25"/>
      <Setter Property="ClipToBounds" Value="True"/>
      <Setter Property="Margin" Value="0,0,18,18"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.2"/>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Border.contentCard:pointerover">
      <Setter Property="Background" Value="#142333"/>
      <Setter Property="BorderBrush" Value="#64C7E8"/>
    </Style>

    <Style Selector="Border.modrinthHero">
      <Setter Property="CornerRadius" Value="24"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="#2E3040"/>
      <Setter Property="Background">
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
          <GradientStop Color="#182230" Offset="0"/>
          <GradientStop Color="#11161E" Offset="0.55"/>
          <GradientStop Color="#101318" Offset="1"/>
        </LinearGradientBrush>
      </Setter>
    </Style>

    <Style Selector="Border.modrinthChip">
      <Setter Property="CornerRadius" Value="999"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="#334155"/>
      <Setter Property="Background" Value="#17202B"/>
      <Setter Property="Padding" Value="10,5"/>
    </Style>

    <Style Selector="ToggleButton.modrinthTab">
      <Setter Property="Background" Value="#171C23"/>
      <Setter Property="Foreground" Value="#A7AFBC"/>
      <Setter Property="BorderBrush" Value="#313746"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="16,10"/>
      <Setter Property="CornerRadius" Value="999"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="ToggleButton.modrinthTab:pointerover">
      <Setter Property="Background" Value="#1E2530"/>
      <Setter Property="Foreground" Value="#FFFFFF"/>
      <Setter Property="BorderBrush" Value="#46607A"/>
    </Style>

    <Style Selector="ToggleButton.modrinthTab:checked">
      <Setter Property="Background" Value="#212D3C"/>
      <Setter Property="Foreground" Value="#FFFFFF"/>
      <Setter Property="BorderBrush" Value="#65C2FF"/>
    </Style>

    <Style Selector="TextBox.modrinthSearch">
      <Setter Property="Background" Value="#12171D"/>
      <Setter Property="Foreground" Value="#F5F5F5"/>
      <Setter Property="BorderBrush" Value="#313A45"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="14"/>
      <Setter Property="Padding" Value="16,12"/>
    </Style>

    <Style Selector="Button.modrinthPrimary">
      <Setter Property="Background" Value="#21C7E5"/>
      <Setter Property="Foreground" Value="#FFFFFF"/>
      <Setter Property="BorderBrush" Value="#71E8FF"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="16,10"/>
      <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style Selector="Button.modrinthPrimary:pointerover">
      <Setter Property="Background" Value="#35D7F2"/>
    </Style>

    <Style Selector="Button.modrinthGhost">
      <Setter Property="Background" Value="#181C23"/>
      <Setter Property="Foreground" Value="#F5F5F5"/>
      <Setter Property="BorderBrush" Value="#313746"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="16,10"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="Button.modrinthGhost:pointerover">
      <Setter Property="Background" Value="#212832"/>
      <Setter Property="BorderBrush" Value="#4F657E"/>
    </Style>

    <Style Selector="ProgressBar#ContentLoadingBar">
      <Setter Property="Minimum" Value="0"/>
      <Setter Property="Maximum" Value="100"/>
      <Setter Property="Value" Value="0"/>
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Value" Duration="0:0:0.32"/>
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="ListBox#ModpackList">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style Selector="ListBox#ModpackList ListBoxItem">
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Margin" Value="0"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    </Style>

    <Style Selector="ListBox#ModpackList ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style Selector="Button.discordServerPill">
      <Setter Property="Background" Value="#1A1B1F"/>
      <Setter Property="BorderBrush" Value="#2F3136"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="16"/>
      <Setter Property="Padding" Value="14,12"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.discordServerPill:pointerover">
      <Setter Property="Background" Value="#25262C"/>
      <Setter Property="BorderBrush" Value="#5865F2"/>
    </Style>
  </Window.Styles>

  <Grid>
    <Grid ColumnDefinitions="292,*" Margin="0">
    <!-- Liquid glass sidebar (neutral / warm highlights) -->
    <Border x:Name="NavGlassHost"
            Grid.Column="0"
            Margin="16,16,8,16"
            Padding="4">
      <Grid RowDefinitions="Auto,*,Auto">
        <Border Margin="8,8,8,4"
                Padding="12,10"
                CornerRadius="18"
                BorderBrush="#2E3040"
                BorderThickness="1"
                HorizontalAlignment="Stretch">
          <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
              <GradientStop Color="#1C1C24" Offset="0"/>
              <GradientStop Color="#12121A" Offset="1"/>
            </LinearGradientBrush>
          </Border.Background>
          <Grid ColumnDefinitions="Auto,*">
            <Border Width="46" Height="46" CornerRadius="13" ClipToBounds="True" VerticalAlignment="Center"
                    BorderBrush="#3A3D46" BorderThickness="1" Background="#25252C">
              <Image x:Name="SidebarBrandImage" Stretch="UniformToFill"/>
            </Border>
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2" Margin="12,0,0,0">
              <TextBlock Text="XylarJava"
                         FontSize="19"
                         FontWeight="Bold"
                         LetterSpacing="-0.6"
                         Foreground="#F2F2F8"/>
              <TextBlock Text="Launcher"
                         FontSize="11"
                         FontWeight="SemiBold"
                         Classes="epicMuted"
                         Opacity="0.88"/>
            </StackPanel>
          </Grid>
        </Border>

        <StackPanel Grid.Row="1" Margin="4,0,4,0" Spacing="6" VerticalAlignment="Center">
          <ToggleButton x:Name="NavMain" Classes="epicNav" Content="Home" IsChecked="True" Click="NavButton_Click"/>
          <ToggleButton x:Name="NavSkins" Classes="epicNav" Content="Settings" Click="NavButton_Click"/>
          <ToggleButton x:Name="NavMods" Classes="epicNav" Content="Modspack" Click="NavButton_Click"/>
          <ToggleButton x:Name="NavCredits" Classes="epicNav" Content="About" Click="NavButton_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="12,0,12,14" Spacing="8">
          <Border Height="1" Background="#28FFFFFF" Margin="0,0,0,4"/>
          <TextBlock Text="Made by Mrmariix"
                     FontSize="12"
                     FontWeight="SemiBold"
                     Foreground="#EBEBF0"
                     TextWrapping="Wrap"
                     LineHeight="16"/>
          <TextBlock Text="Not affiliated with Mojang, Microsoft, or Minecraft."
                     FontSize="10"
                     Classes="epicMuted"
                     TextWrapping="Wrap"
                     Opacity="0.72"
                     LineHeight="14"/>
        </StackPanel>
        <StackPanel IsVisible="False">
          <Border Width="1" Height="1">
            <Image x:Name="ProfileAvatarImage" Source="/Assets/steve.png"/>
          </Border>
          <TextBlock x:Name="HeroStatusText"/>
          <TextBlock x:Name="SelectionSummaryText"/>
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Column="1" Margin="8,16,16,16" RowDefinitions="Auto,*">
      <Grid Grid.Row="0" Margin="0,0,0,12" ColumnDefinitions="*">
        <StackPanel Spacing="4" VerticalAlignment="Center">
          <TextBlock x:Name="HeaderTitleText" Text="Home" FontSize="24" FontWeight="Bold"/>
          <TextBlock x:Name="HeaderSubtitleText" Text="Version, loader, modpacks." Classes="epicMuted" FontSize="13"/>
        </StackPanel>
      </Grid>

      <Grid Grid.Row="1">
        <Border x:Name="MainSection" Classes="epicContentShell">
          <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <Grid Margin="24" RowDefinitions="Auto,*" ColumnDefinitions="420,*">
              <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Classes="epicHero" Margin="0,0,0,18">
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                  <StackPanel Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="Ready when you are" FontSize="30" FontWeight="Bold"/>
                    <TextBlock Text="Choose a version, pick a loader, then launch." Classes="epicMuted" TextWrapping="Wrap" MaxWidth="720"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                      <Border Background="#2A2A30" CornerRadius="8" Padding="12,8">
                        <TextBlock x:Name="HeroVersionText" Classes="epicCaption"/>
                      </Border>
                      <Border Background="#2A2A30" CornerRadius="8" Padding="12,8">
                        <TextBlock x:Name="HeroLoaderText" Classes="epicCaption"/>
                      </Border>
                    </StackPanel>
                  </StackPanel>

                  <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,18,0,0" Orientation="Horizontal" Spacing="10">
                    <Border Classes="epicMetric">
                      <StackPanel Spacing="3">
                        <TextBlock Text="Session" Classes="epicCaption"/>
                        <TextBlock Text="Launcher ready" FontWeight="SemiBold"/>
                      </StackPanel>
                    </Border>
                    <Border Classes="epicMetric">
                      <StackPanel Spacing="3">
                        <TextBlock Text="Target" Classes="epicCaption"/>
                        <TextBlock Text="Standard profile" FontWeight="SemiBold"/>
                      </StackPanel>
                    </Border>
                    <Border Classes="epicMetric">
                      <StackPanel Spacing="3">
                        <TextBlock Text="Stack" Classes="epicCaption"/>
                        <TextBlock Text="Vanilla / Fabric / Forge" FontWeight="SemiBold"/>
                      </StackPanel>
                    </Border>
                  </StackPanel>
                </Grid>
              </Border>

              <StackPanel Grid.Row="1" Grid.Column="0" Spacing="14">
                <Border Classes="epicPanel">
                  <StackPanel Spacing="14">
                    <TextBlock Text="Profile" FontSize="17" FontWeight="SemiBold"/>
                    <TextBlock Text="Your current launch setup." Classes="epicMuted" TextWrapping="Wrap"/>

                    <StackPanel Spacing="6" IsVisible="False">
                      <TextBlock Text="Launch name" Classes="epicCaption"/>
                      <TextBox x:Name="UsernameBox" Height="44" Watermark="Your in-game name"/>
                    </StackPanel>

                    <StackPanel Spacing="6">
                      <TextBlock Text="Play profile (installed modpacks)" Classes="epicCaption"/>
                      <ComboBox x:Name="ProfileTargetCombo" Height="44"/>
                      <TextBlock Text="Installed packs appear here automatically." Classes="epicMuted" FontSize="11" TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Spacing="6">
                      <TextBlock Text="Minecraft version" Classes="epicCaption"/>
                      <ComboBox x:Name="VersionCombo" Height="44"/>
                    </StackPanel>

                    <StackPanel Spacing="6">
                      <TextBlock Text="Loader" Classes="epicCaption"/>
                      <ComboBox x:Name="LoaderCombo" Height="44">
                        <ComboBoxItem Content="Vanilla" IsSelected="True"/>
                        <ComboBoxItem Content="Fabric"/>
                        <ComboBoxItem Content="Forge"/>
                        <ComboBoxItem Content="NeoForge"/>
                        <ComboBoxItem Content="Quilt"/>
                      </ComboBox>
                    </StackPanel>

                    <StackPanel Spacing="6">
                      <TextBlock Text="Version list" Classes="epicCaption"/>
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <ToggleButton x:Name="ReleaseFilter" Classes="epicFilter" Content="Release" IsChecked="True" Click="VersionFilterButton_Click"/>
                        <ToggleButton x:Name="InstalledFilter" Classes="epicFilter" Content="Installed" Click="VersionFilterButton_Click"/>
                        <ToggleButton x:Name="AllFilter" Classes="epicFilter" Content="All" Click="VersionFilterButton_Click"/>
                      </StackPanel>
                    </StackPanel>

                    <Border Background="#25252C" BorderBrush="#3A3A42" BorderThickness="1" CornerRadius="10" Padding="12,10">
                      <TextBlock x:Name="LoaderWarning" FontSize="12" TextWrapping="Wrap"/>
                    </Border>

                    <Grid ColumnDefinitions="*,*">
                      <Border Classes="epicQuickAction">
                        <StackPanel Spacing="2">
                          <TextBlock Text="Versions" Classes="epicCaption"/>
                          <TextBlock Text="Use Installed for quick filtering" FontWeight="SemiBold" FontSize="12"/>
                        </StackPanel>
                      </Border>
                      <Border Grid.Column="1" Classes="epicQuickAction" Margin="10,0,0,0">
                        <StackPanel Spacing="2">
                          <TextBlock Text="Target" Classes="epicCaption"/>
                          <TextBlock Text="Pick an installed pack target" FontWeight="SemiBold" FontSize="12"/>
                        </StackPanel>
                      </Border>
                    </Grid>
                  </StackPanel>
                </Border>

                <Border Classes="epicPanel">
                  <StackPanel Spacing="12">
                    <Button x:Name="LaunchButton"
                            Classes="epicPrimary"
                            Content="Launch Minecraft"
                            Height="52"
                            FontSize="15"
                            HorizontalAlignment="Stretch"
                            Click="LaunchButton_Click"/>
                    <Border Background="#1B1C22" BorderBrush="#2F3138" BorderThickness="1" CornerRadius="8" Padding="10,8">
                      <ProgressBar x:Name="DownloadProgress" Height="6" Minimum="0" Maximum="100" Value="0"/>
                    </Border>
                    <TextBlock x:Name="StatusText" Classes="epicMuted" FontSize="12" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <Button Classes="epicGhost"
                              Content="Refresh versions"
                              Height="34"
                              Click="RefreshVersionsButton_Click"/>
                      <Button Classes="epicGhost"
                              Content="Open instances"
                              Height="34"
                              Click="OpenInstancesFolder_Click"/>
                    </StackPanel>
                  </StackPanel>
                </Border>

                <Border Classes="epicPanel">
                  <StackPanel Spacing="10">
                    <TextBlock Text="Activity Log" FontSize="17" FontWeight="SemiBold"/>
                    <ProgressBar x:Name="MainLoadingBar" Height="6" Minimum="0" Maximum="100" Value="0" IsVisible="False"/>
                    <Border Background="#0D0D10" BorderBrush="#2F3138" BorderThickness="1" CornerRadius="8" Padding="10" Height="200">
                      <ScrollViewer x:Name="LogScrollViewer" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="LogOutputText" Classes="epicMuted" FontSize="11" TextWrapping="Wrap" FontFamily="Consolas,Monospace"/>
                      </ScrollViewer>
                    </Border>
                  </StackPanel>
                </Border>
              </StackPanel>

              <StackPanel Grid.Row="1" Grid.Column="1" Margin="22,0,0,0" Spacing="14">
                <Border Classes="epicPanel">
                  <StackPanel Spacing="12">
                    <TextBlock Text="Session summary" FontSize="17" FontWeight="SemiBold"/>
                    <TextBlock x:Name="CurrentVersionLabel" Classes="epicMuted"/>
                    <TextBlock x:Name="CurrentLoaderLabel" Classes="epicMuted"/>
                    <TextBlock x:Name="CurrentPlayerLabel" Classes="epicMuted"/>
                    <TextBlock x:Name="SelectionSummaryLabel" Classes="epicMuted" TextWrapping="Wrap"/>
                  </StackPanel>
                </Border>
                <Border Classes="epicPanel">
                  <StackPanel Spacing="10">
                    <TextBlock Text="Launch target" FontSize="17" FontWeight="SemiBold"/>
                    <TextBlock x:Name="ActiveTargetTitle" Text="Standard profile" FontWeight="SemiBold"/>
                    <TextBlock x:Name="ActiveTargetSubtitle" Classes="epicMuted" TextWrapping="Wrap"/>
                    <TextBlock x:Name="ActiveTargetStatus" Classes="epicCaption" TextWrapping="Wrap"/>
                  </StackPanel>
                </Border>
              </StackPanel>
            </Grid>
          </ScrollViewer>
        </Border>

        <Border x:Name="SkinSection" Classes="epicContentShell" IsVisible="False">
          <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="28,24,28,32" Spacing="20" MaxWidth="960">
              <Border Padding="24,20" CornerRadius="16" BorderBrush="#2E3040" BorderThickness="1">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="1,0.5">
                    <GradientStop Color="#1E1E26" Offset="0"/>
                    <GradientStop Color="#14141A" Offset="1"/>
                  </LinearGradientBrush>
                </Border.Background>
                <StackPanel Spacing="10">
                  <TextBlock Text="OfflineSkins Mod" FontSize="28" FontWeight="Bold" LetterSpacing="-0.5"/>
                  <TextBlock Text="Play offline Minecraft with custom skins using the Fabric mod OfflineSkins. Full setup guide below." Classes="epicMuted" TextWrapping="Wrap" FontSize="13" LineHeight="20"/>
                  <Button Classes="epicPrimary" Content="Open OfflineSkins on Modrinth" Margin="0,8,0,0" Height="40" Padding="16,0" Click="OpenOfflineSkinsModPage_Click" HorizontalAlignment="Left"/>
                </StackPanel>
              </Border>

              <Border Classes="epicPanel">
                <StackPanel Spacing="12">
                  <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                    <Border Grid.Column="0" Grid.Row="0" Width="48" Height="48" CornerRadius="10" Background="#2A2A30" BorderBrush="#3A3A42" BorderThickness="1" Padding="8">
                      <TextBlock Text="1" FontSize="24" FontWeight="Bold" Foreground="#D8D8E0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Grid.Row="0" Margin="16,0,0,0" VerticalAlignment="Center" Spacing="2">
                      <TextBlock Text="Requirements" FontSize="16" FontWeight="SemiBold"/>
                      <TextBlock Text="Java Edition · Fabric 1.21+ · OfflineSkins mod" Classes="epicMuted" FontSize="12"/>
                    </StackPanel>
                    <TextBlock Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1" Margin="0,12,0,0" TextWrapping="Wrap" FontSize="12" LineHeight="18" Classes="epicMuted">
                      Download Fabric for your Minecraft version from the official Fabric website. OfflineSkins is a client-only Fabric mod; you must have Fabric Loader installed.
                    </TextBlock>
                  </Grid>
                </StackPanel>
              </Border>

              <Border Classes="epicPanel">
                <StackPanel Spacing="12">
                  <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                    <Border Grid.Column="0" Grid.Row="0" Width="48" Height="48" CornerRadius="10" Background="#2A2A30" BorderBrush="#3A3A42" BorderThickness="1" Padding="8">
                      <TextBlock Text="2" FontSize="24" FontWeight="Bold" Foreground="#D8D8E0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Grid.Row="0" Margin="16,0,0,0" VerticalAlignment="Center" Spacing="2">
                      <TextBlock Text="Install Fabric" FontSize="16" FontWeight="SemiBold"/>
                      <TextBlock Text="Run the Fabric installer, choose Client" Classes="epicMuted" FontSize="12"/>
                    </StackPanel>
                    <TextBlock Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1" Margin="0,12,0,0" TextWrapping="Wrap" FontSize="12" LineHeight="18" Classes="epicMuted">
                      Download the Fabric installer from fabric.net, run it, select your Minecraft version, and install to your .minecraft directory (or the custom game directory you use with this launcher).
                    </TextBlock>
                  </Grid>
                </StackPanel>
              </Border>

              <Border Classes="epicPanel">
                <StackPanel Spacing="12">
                  <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                    <Border Grid.Column="0" Grid.Row="0" Width="48" Height="48" CornerRadius="10" Background="#2A2A30" BorderBrush="#3A3A42" BorderThickness="1" Padding="8">
                      <TextBlock Text="3" FontSize="24" FontWeight="Bold" Foreground="#D8D8E0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Grid.Row="0" Margin="16,0,0,0" VerticalAlignment="Center" Spacing="2">
                      <TextBlock Text="Download Mod" FontSize="16" FontWeight="SemiBold"/>
                      <TextBlock Text="Get the .jar file from Modrinth" Classes="epicMuted" FontSize="12"/>
                    </StackPanel>
                    <TextBlock Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1" Margin="0,12,0,0" TextWrapping="Wrap" FontSize="12" LineHeight="18" Classes="epicMuted">
                      On Modrinth, find OfflineSkins and download the .jar matching your Minecraft version. Do not unzip the file.
                    </TextBlock>
                  </Grid>
                </StackPanel>
              </Border>

              <Border Classes="epicPanel">
                <StackPanel Spacing="12">
                  <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                    <Border Grid.Column="0" Grid.Row="0" Width="48" Height="48" CornerRadius="10" Background="#2A2A30" BorderBrush="#3A3A42" BorderThickness="1" Padding="8">
                      <TextBlock Text="4" FontSize="24" FontWeight="Bold" Foreground="#D8D8E0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Grid.Row="0" Margin="16,0,0,0" VerticalAlignment="Center" Spacing="2">
                      <TextBlock Text="Place Mod" FontSize="16" FontWeight="SemiBold"/>
                      <TextBlock Text="Move .jar to .minecraft/mods/" Classes="epicMuted" FontSize="12"/>
                    </StackPanel>
                    <TextBlock Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1" Margin="0,12,0,0" TextWrapping="Wrap" FontSize="12" LineHeight="18" Classes="epicMuted">
                      Copy the OfflineSkins .jar file into your game directory's mods folder. Create the mods folder if it does not exist.
                    </TextBlock>
                  </Grid>
                </StackPanel>
              </Border>

              <Border Classes="epicPanel">
                <StackPanel Spacing="12">
                  <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                    <Border Grid.Column="0" Grid.Row="0" Width="48" Height="48" CornerRadius="10" Background="#2A2A30" BorderBrush="#3A3A42" BorderThickness="1" Padding="8">
                      <TextBlock Text="5" FontSize="24" FontWeight="Bold" Foreground="#D8D8E0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Grid.Row="0" Margin="16,0,0,0" VerticalAlignment="Center" Spacing="2">
                      <TextBlock Text="Config Folder" FontSize="16" FontWeight="SemiBold"/>
                      <TextBlock Text="Create config/offlineskins/" Classes="epicMuted" FontSize="12"/>
                    </StackPanel>
                    <TextBlock Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1" Margin="0,12,0,0" TextWrapping="Wrap" FontSize="12" LineHeight="18" Classes="epicMuted">
                      Create a config/offlineskins/ folder in the same game directory. This is where the mod looks for your PNG skin files.
                    </TextBlock>
                  </Grid>
                </StackPanel>
              </Border>

              <Border Classes="epicPanel">
                <StackPanel Spacing="12">
                  <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                    <Border Grid.Column="0" Grid.Row="0" Width="48" Height="48" CornerRadius="10" Background="#2A2A30" BorderBrush="#3A3A42" BorderThickness="1" Padding="8">
                      <TextBlock Text="6" FontSize="24" FontWeight="Bold" Foreground="#D8D8E0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Grid.Row="0" Margin="16,0,0,0" VerticalAlignment="Center" Spacing="2">
                      <TextBlock Text="Add Skins" FontSize="16" FontWeight="SemiBold"/>
                      <TextBlock Text="Copy PNG files matching your username" Classes="epicMuted" FontSize="12"/>
                    </StackPanel>
                    <TextBlock Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1" Margin="0,12,0,0" TextWrapping="Wrap" FontSize="12" LineHeight="18" Classes="epicMuted">
                      Export or download Minecraft skins (64x64 or 64x32 PNG). Copy them into config/offlineskins/. File names must match your in-game name: if your username is OfflineUser, name the file OfflineUser.png.
                    </TextBlock>
                  </Grid>
                </StackPanel>
              </Border>

              <Border Classes="epicPanel">
                <StackPanel Spacing="12">
                  <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                    <Border Grid.Column="0" Grid.Row="0" Width="48" Height="48" CornerRadius="10" Background="#2A2A30" BorderBrush="#3A3A42" BorderThickness="1" Padding="8">
                      <TextBlock Text="7" FontSize="24" FontWeight="Bold" Foreground="#D8D8E0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Grid.Row="0" Margin="16,0,0,0" VerticalAlignment="Center" Spacing="2">
                      <TextBlock Text="Launch &amp; Apply" FontSize="16" FontWeight="SemiBold"/>
                      <TextBlock Text="Use /offlineskins commands in-game" Classes="epicMuted" FontSize="12"/>
                    </StackPanel>
                    <TextBlock Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1" Margin="0,12,0,0" TextWrapping="Wrap" FontSize="12" LineHeight="18" Classes="epicMuted">
                      Launch Minecraft with Fabric. In-game, use /offlineskins list to see available skins, /offlineskins change [name] to apply one, or /offlineskins default [steve|alex] to reset.
                    </TextBlock>
                  </Grid>
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>
        </Border>

        <Border x:Name="ModSection" Classes="epicContentShell" IsVisible="False">
          <Grid Margin="28" ColumnDefinitions="290,*">
            <Border Grid.Column="0"
                    Classes="epicPanel"
                    Padding="22"
                    CornerRadius="22">
              <StackPanel Spacing="16">
                <Border Classes="modrinthChip"
                        HorizontalAlignment="Left">
                  <TextBlock Text="MODSPACK"
                             FontSize="11"
                             FontWeight="Bold"
                             Foreground="#9FE2FF"/>
                </Border>

                <TextBlock Text="Modpacks only"
                           FontSize="28"
                           FontWeight="Bold"
                           TextWrapping="Wrap"/>

                <TextBlock Text="Search curated Modrinth packs, pick a downloaded version, then install into a dedicated instance."
                           Classes="epicMuted"
                           FontSize="13"
                           LineHeight="20"
                           TextWrapping="Wrap"/>

                <TextBox x:Name="ContentSearchBox"
                         Classes="modrinthSearch"
                         Height="48"
                         Watermark="Search modpacks, e.g. Better MC"
                         KeyUp="ContentSearchBox_KeyUp"/>

                <Button Classes="modrinthPrimary"
                        Content="Search"
                        Height="46"
                        Click="ContentSearch_Click"/>

                <ProgressBar x:Name="ContentLoadingBar"
                             Height="6"
                             IsVisible="False"/>

                <TextBlock x:Name="ContentStatusText"
                           Text="Discover popular modpacks from Modrinth."
                           TextWrapping="Wrap"
                           Foreground="#A5B4C2"
                           FontSize="12"
                           LineHeight="18"/>

                <Border Classes="epicQuickAction">
                  <StackPanel Spacing="4">
                    <TextBlock Text="Install flow" Classes="epicCaption"/>
                    <TextBlock Text="Install picks only already-downloaded Minecraft versions." FontWeight="SemiBold" FontSize="12" TextWrapping="Wrap"/>
                  </StackPanel>
                </Border>

                <Border Classes="epicQuickAction">
                  <StackPanel Spacing="4">
                    <TextBlock Text="Source" Classes="epicCaption"/>
                    <TextBlock Text="Modrinth modpack catalog" FontWeight="SemiBold" FontSize="12" TextWrapping="Wrap"/>
                  </StackPanel>
                </Border>
              </StackPanel>
            </Border>

            <ScrollViewer Grid.Column="1"
                          Margin="20,0,0,0"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
              <StackPanel Spacing="18">
                <Border Classes="modrinthHero"
                        Padding="28,26">
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="12">
                      <TextBlock Text="Build your next stack"
                                 FontSize="34"
                                 FontWeight="Bold"
                                 LetterSpacing="-0.8"
                                 TextWrapping="Wrap"
                                 MaxWidth="700"/>
                      <TextBlock Text="Only modpacks are shown here now. Open the pack page, check support, or install directly into a clean instance."
                                 Foreground="#B7C3D1"
                                 TextWrapping="Wrap"
                                 FontSize="14"
                                 LineHeight="22"
                                 MaxWidth="700"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Margin="28,0,0,0"
                                Spacing="12"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right">
                      <Border Classes="modrinthChip" HorizontalAlignment="Right">
                        <TextBlock Text="Source: Modrinth" FontSize="12" FontWeight="SemiBold"/>
                      </Border>
                      <Border Classes="modrinthChip" HorizontalAlignment="Right">
                        <TextBlock Text="Only compatible installed versions are offered" FontSize="12" FontWeight="SemiBold"/>
                      </Border>
                    </StackPanel>
                  </Grid>
                </Border>

                <ItemsControl x:Name="ContentItemsControl"
                              Padding="0,0,12,0">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Classes="contentCard"
                              Width="336">
                        <Grid RowDefinitions="Auto,Auto,Auto">
                          <Grid Margin="18,18,18,0" ColumnDefinitions="72,*,Auto">
                            <Border Width="72"
                                    Height="72"
                                    CornerRadius="18"
                                    BorderBrush="#33597D"
                                    BorderThickness="1"
                                    Background="#162636">
                              <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"/>
                            </Border>

                            <StackPanel Grid.Column="1"
                                        Margin="14,0,0,0"
                                        Spacing="7"
                                        VerticalAlignment="Center">
                              <WrapPanel Orientation="Horizontal">
                                <Border Classes="modrinthChip" Margin="0,0,8,6">
                                  <TextBlock Text="{Binding DisplaySourceName}" FontSize="11" FontWeight="Bold" Foreground="#9FE2FF"/>
                                </Border>
                                <Border Classes="modrinthChip" Margin="0,0,0,6">
                                  <TextBlock Text="Modpack" FontSize="11" FontWeight="Bold"/>
                                </Border>
                              </WrapPanel>
                              <TextBlock Text="{Binding Title}"
                                         FontSize="18"
                                         FontWeight="Bold"
                                         TextWrapping="Wrap"
                                         MaxHeight="50"/>
                              <TextBlock Text="{Binding DisplayAuthor}"
                                         Foreground="#A7B7C6"
                                         FontSize="12"
                                         TextWrapping="Wrap"/>
                            </StackPanel>

                            <Button Grid.Column="2"
                                    Margin="14,0,0,0"
                                    Classes="modrinthGhost"
                                    Content="Open"
                                    Height="38"
                                    VerticalAlignment="Top"
                                    Click="ContentOpenPage_Click"/>
                          </Grid>

                          <StackPanel Grid.Row="1" Margin="18,16,18,0" Spacing="12">
                            <TextBlock Text="{Binding Description}"
                                       Foreground="#D8E0E7"
                                       FontSize="13"
                                       LineHeight="20"
                                       TextWrapping="Wrap"
                                       MaxHeight="64"/>

                            <WrapPanel Orientation="Horizontal">
                              <Border Classes="modrinthChip" Margin="0,0,8,8">
                                <TextBlock Text="{Binding DisplayPrimaryCategory}" FontSize="11"/>
                              </Border>
                              <Border Classes="modrinthChip" Margin="0,0,8,8">
                                <TextBlock Text="{Binding DisplayLoaderSummary}" FontSize="11"/>
                              </Border>
                              <Border Classes="modrinthChip" Margin="0,0,0,8">
                                <TextBlock Text="{Binding DisplayUpdated}" FontSize="11"/>
                              </Border>
                            </WrapPanel>
                          </StackPanel>

                          <Grid Grid.Row="2" Margin="18,0,18,18" ColumnDefinitions="*,Auto">
                            <StackPanel VerticalAlignment="Center" Spacing="3">
                              <TextBlock Text="{Binding DownloadCount, StringFormat='{}{0:N0} downloads'}"
                                         FontSize="13"
                                         FontWeight="SemiBold"/>
                              <TextBlock Text="Version and loader are picked during install."
                                         FontSize="11"
                                         Foreground="#8DA0B2"
                                         TextWrapping="Wrap"/>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Margin="10,0,0,0"
                                    Classes="modrinthPrimary"
                                    Content="Install pack"
                                    Height="40"
                                    Click="InstallMod_Click"/>
                          </Grid>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button x:Name="LoadMoreContentButton"
                        Classes="modrinthGhost"
                        Content="Load more"
                        Height="46"
                        Width="180"
                        HorizontalAlignment="Center"
                        IsVisible="False"
                        Click="LoadMoreContent_Click"/>
              </StackPanel>
            </ScrollViewer>
          </Grid>
        </Border>

        <Border x:Name="OptionsSection" Classes="epicContentShell" IsVisible="False">
          <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,28,32,40" Spacing="24" MaxWidth="980">
              <Border Padding="24,22" CornerRadius="18" BorderBrush="#2E3040" BorderThickness="1">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="1,0.6">
                    <GradientStop Color="#162332" Offset="0"/>
                    <GradientStop Color="#10161F" Offset="1"/>
                  </LinearGradientBrush>
                </Border.Background>
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel Spacing="10">
                    <TextBlock Text="Settings" FontSize="32" FontWeight="Bold" LetterSpacing="-0.8"/>
                    <TextBlock Text="Account, folders and launch."
                               Classes="epicMuted"
                               TextWrapping="Wrap"
                               FontSize="14"
                               LineHeight="21"
                               MaxWidth="620"/>
                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,6,0,0">
                      <Border x:Name="SettingsModeChip"
                              Background="#17344657"
                              BorderBrush="#2E6AA0D5"
                              BorderThickness="1"
                              CornerRadius="999"
                              Padding="12,6">
                        <TextBlock x:Name="SettingsAccountModeText"
                                   Text="Offline"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="#7DE6FF"/>
                      </Border>
                      <TextBlock x:Name="SettingsLaunchNameText"
                                 Text="Launch name: OfflineUser"
                                 Classes="epicMuted"
                                 VerticalAlignment="Center"/>
                    </StackPanel>
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="10" VerticalAlignment="Center">
                    <Button Classes="epicMicrosoft"
                            Content="Sign in Microsoft"
                            Width="210"
                            Height="42"
                            Click="SettingsMicrosoftSignIn_Click"/>
                    <Button Classes="epicSecondary"
                            Content="Go offline"
                            Width="210"
                            Height="42"
                            Click="SettingsOfflineMode_Click"/>
                  </StackPanel>
                </Grid>
              </Border>

              <Grid ColumnDefinitions="*,*">
                <Border Classes="epicPanel" Margin="0,0,7,0">
                  <StackPanel Spacing="14">
                    <TextBlock Text="Account" FontSize="18" FontWeight="Bold"/>
                    <TextBlock x:Name="SettingsAccountHeadlineText"
                               Text="Offline mode is active"
                               FontSize="20"
                               FontWeight="SemiBold"/>
                    <TextBlock x:Name="SettingsAccountDetailText"
                               Text="Launch offline now, or switch to Microsoft when you want an online account."
                               Classes="epicMuted"
                               TextWrapping="Wrap"
                               FontSize="13"
                               LineHeight="20"/>
                    <Border Height="1" Background="#28FFFFFF"/>
                    <TextBlock Text="The launcher refreshes the Microsoft session again automatically at launch if needed."
                               Classes="epicMuted"
                               TextWrapping="Wrap"
                               FontSize="12"
                               LineHeight="18"/>
                  </StackPanel>
                </Border>

                <Border Grid.Column="1" Classes="epicPanel" Margin="7,0,0,0">
                  <StackPanel Spacing="14">
                    <TextBlock Text="Folders" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="Quick shortcuts for the launcher, instances and base Minecraft folder."
                               Classes="epicMuted"
                               TextWrapping="Wrap"
                               FontSize="13"
                               LineHeight="20"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <Button Classes="epicSecondary"
                              Content="Launcher folder"
                              Height="40"
                              Click="OpenLauncherFolder_Click"/>
                      <Button Classes="epicSecondary"
                              Content="Instances folder"
                              Height="40"
                              Click="OpenInstancesFolder_Click"/>
                    </StackPanel>
                    <Button Classes="epicSecondary"
                            Content="Minecraft folder"
                            Height="40"
                            Click="OpenMinecraftFolder_Click"/>
                  </StackPanel>
                </Border>
              </Grid>

              <Grid ColumnDefinitions="*">
                <Border Classes="epicPanel">
                  <StackPanel Spacing="14">
                    <TextBlock Text="Launch &amp; performance" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text=".NET is bundled in release builds. Java is checked only when you actually launch Minecraft."
                               Classes="epicMuted"
                               TextWrapping="Wrap"
                               FontSize="13"
                               LineHeight="20"/>
                    <StackPanel Spacing="8">
                      <TextBlock Text="Recommended setup" Classes="epicCaption"/>
                      <TextBlock Text="Choose a downloaded version, pick Vanilla, Fabric, Forge, NeoForge or Quilt."
                                 Classes="epicMuted"
                                 TextWrapping="Wrap"
                                 FontSize="12"
                                 LineHeight="18"/>
                    </StackPanel>
                    <StackPanel Spacing="8">
                      <TextBlock Text="Interface" Classes="epicCaption"/>
                      <TextBlock Text="Settings keeps only the controls that matter for account and launcher management."
                                 Classes="epicMuted"
                                 TextWrapping="Wrap"
                                 FontSize="12"
                                 LineHeight="18"/>
                    </StackPanel>
                  </StackPanel>
                </Border>
              </Grid>
            </StackPanel>
          </ScrollViewer>
        </Border>

        <Border x:Name="CreditsSection" Classes="epicContentShell" IsVisible="False">
          <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="28,24,28,36" Spacing="22" MaxWidth="960">
              <Border Padding="22,20" CornerRadius="18" BorderBrush="#2E3040" BorderThickness="1">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="1,0.5">
                    <GradientStop Color="#1E1E26" Offset="0"/>
                    <GradientStop Color="#14141A" Offset="1"/>
                  </LinearGradientBrush>
                </Border.Background>
                <StackPanel Spacing="8">
                  <TextBlock Text="About Xylar" FontSize="30" FontWeight="Bold" LetterSpacing="-0.8"/>
                  <TextBlock Text="Desktop launcher for Minecraft Java Edition with Modrinth modpack install, loader switching and account tools." Classes="epicMuted" TextWrapping="Wrap" FontSize="13" LineHeight="20"/>
                </StackPanel>
              </Border>

              <TextBlock Text="Community" FontSize="14" FontWeight="SemiBold" Classes="epicCaption" Margin="0,4,0,0"/>
              <StackPanel Spacing="12">
                <Button Classes="discordServerPill" Click="DiscordXylarInc_Click">
                  <Grid ColumnDefinitions="Auto,*">
                    <Border Width="56" Height="56" CornerRadius="14" ClipToBounds="True" BorderBrush="#3A3D46" BorderThickness="1" Background="#25252C">
                      <Image x:Name="AboutLogoXylarInc" Stretch="UniformToFill"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4" Margin="16,0,0,0">
                      <TextBlock Text="Xylar Inc." FontSize="16" FontWeight="Bold"/>
                      <TextBlock Text="discord.gg/CQ6Et3Kws7" Classes="epicMuted" FontSize="12"/>
                      <TextBlock Text="Tap to open Discord" FontSize="11" Opacity="0.75" Classes="epicCaption"/>
                    </StackPanel>
                  </Grid>
                </Button>
                <Button Classes="discordServerPill" Click="DiscordXylarSupport_Click">
                  <Grid ColumnDefinitions="Auto,*">
                    <Border Width="56" Height="56" CornerRadius="14" ClipToBounds="True" BorderBrush="#3A3D46" BorderThickness="1" Background="#25252C">
                      <Image x:Name="AboutLogoXylarSupport" Stretch="UniformToFill"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4" Margin="16,0,0,0">
                      <TextBlock Text="Xylar Support" FontSize="16" FontWeight="Bold"/>
                      <TextBlock Text="discord.gg/KEHccUvvaX" Classes="epicMuted" FontSize="12"/>
                      <TextBlock Text="Tap to open Discord" FontSize="11" Opacity="0.75" Classes="epicCaption"/>
                    </StackPanel>
                  </Grid>
                </Button>
              </StackPanel>

              <Border Classes="epicPanel">
                <StackPanel Spacing="12">
                  <TextBlock Text="Credits" FontSize="17" FontWeight="SemiBold"/>
                  <TextBlock Text="Made by Mrmariix." FontSize="14" TextWrapping="Wrap"/>
                  <TextBlock Text="Not affiliated with Mojang, Microsoft, or Minecraft. Minecraft is a trademark of Mojang Synergies AB." Classes="epicMuted" TextWrapping="Wrap" FontSize="12" LineHeight="18"/>
                </StackPanel>
              </Border>

              <Border Classes="epicPanel">
                <StackPanel Spacing="10">
                  <TextBlock Text="Build" FontSize="17" FontWeight="SemiBold"/>
                  <TextBlock Text="Version 0.0.0.3 · .NET 8 · Avalonia UI 11" Classes="epicMuted" TextWrapping="Wrap"/>
                  <TextBlock Text="Libraries: CmlLib.Core (install and launch), Modrinth API v2 (search and .mrpack download)." Classes="epicMuted" TextWrapping="Wrap" FontSize="12" LineHeight="18"/>
                </StackPanel>
              </Border>

              <Grid ColumnDefinitions="*,*">
                <Border Classes="epicPanel" Margin="0,0,7,0">
                  <StackPanel Spacing="8">
                    <TextBlock Text="Modpacks" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock Text="Catalog from Modrinth. Install downloads the .mrpack and all indexed files into the instances folder next to the launcher." Classes="epicMuted" TextWrapping="Wrap" FontSize="12" LineHeight="18"/>
                  </StackPanel>
                </Border>
                <Border Grid.Column="1" Classes="epicPanel" Margin="7,0,0,0">
                  <StackPanel Spacing="8">
                    <TextBlock Text="Interface" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock Text="Dark layout, glass-style sidebar, smooth section transitions." Classes="epicMuted" TextWrapping="Wrap" FontSize="12" LineHeight="18"/>
                  </StackPanel>
                </Border>
              </Grid>
            </StackPanel>
          </ScrollViewer>
        </Border>
      </Grid>
    </Grid>
    </Grid>

  <Border x:Name="WelcomeOverlay"
          IsVisible="False"
          Background="#E612131A">
    <Grid RowDefinitions="*,Auto,*">
      <Border Grid.Row="1"
              Width="640"
              Padding="28"
              CornerRadius="18"
              BorderBrush="#3A3D46"
              BorderThickness="1"
              Background="#1A1E28">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12" MaxWidth="620">
        <Border Width="120" Height="76" CornerRadius="10" BorderBrush="#4A4D58" BorderThickness="1" Background="#232833">
          <TextBlock Text="XJ"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     FontSize="28"
                     FontWeight="Bold"
                     Foreground="#8DF4FF"/>
        </Border>
        <TextBlock x:Name="WelcomeTitleText"
                   Text="Welcome to XylarJava"
                   FontSize="34"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"/>
        <TextBlock x:Name="WelcomeSubtitleText"
                   Text="Choose your launcher username"
                   FontSize="16"
                   Classes="epicMuted"
                   HorizontalAlignment="Center"/>
        <StackPanel x:Name="WelcomeInputPanel" IsVisible="True" Spacing="8" Margin="0,14,0,0">
          <TextBox x:Name="WelcomeUsernameBox" Width="320" Height="42" Watermark="Type your username"/>
          <Button x:Name="WelcomeConfirmButton" Width="320" Height="40" Classes="epicPrimary" Content="Save username" Click="WelcomeConfirmButton_Click"/>
        </StackPanel>
      </StackPanel>
      </Border>
    </Grid>
  </Border>

  <Border x:Name="DetailOverlay"
          IsVisible="False"
          Background="#E612131A">
    <Grid>
      <Border Width="1000"
              Padding="0"
              CornerRadius="16"
              BorderBrush="#3A3D46"
              BorderThickness="1"
              Background="#16181D"
              VerticalAlignment="Center"
              HorizontalAlignment="Center">
        <Grid RowDefinitions="Auto,*">
          <Grid Grid.Row="0" Background="#1E2127" Height="56">
            <Button x:Name="DetailCloseButton"
                    Width="44"
                    Height="36"
                    Margin="12,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Classes="epicGhost"
                    Content="X"
                    Foreground="#FF4444"
                    FontWeight="Bold"
                    FontSize="18"
                    Click="DetailCloseButton_Click"/>
            <TextBlock x:Name="DetailTitleText"
                       Text="Install content"
                       FontSize="18"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
          </Grid>

          <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" MaxHeight="750">
            <Grid Margin="32,24" RowDefinitions="Auto,Auto,*" ColumnDefinitions="*,340">
              <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="96" Height="96" CornerRadius="12" Background="#1E2127" BorderBrush="#343949" BorderThickness="1" ClipToBounds="True">
                  <Image x:Name="DetailIconImage" Stretch="UniformToFill"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="20,0,0,0" Spacing="6">
                  <TextBlock x:Name="DetailItemTitle" FontSize="28" FontWeight="Bold" TextWrapping="Wrap"/>
                  <TextBlock x:Name="DetailItemDescription" Classes="epicMuted" FontSize="14" TextWrapping="Wrap" MaxHeight="44"/>
                  <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4,0,0">
                    <TextBlock x:Name="DetailItemDownloads" Classes="epicCaption"/>
                    <TextBlock Text="|" Classes="epicMuted"/>
                    <TextBlock x:Name="DetailSourceText" Classes="epicCaption"/>
                  </StackPanel>
                </StackPanel>
              </Grid>

              <!-- Details tabs disabled - simplified UI -->
              <!-- <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="8" Margin="0,0,0,16">
                <ToggleButton x:Name="DetailTabDesc" Classes="epicFilter" Content="Description" IsChecked="True" Click="DetailsTab_Click"/>
                <ToggleButton x:Name="DetailTabChangelog" Classes="epicFilter" Content="Changelog" Click="DetailsTab_Click"/>
                <ToggleButton x:Name="DetailTabVersions" Classes="epicFilter" Content="Versions" Click="DetailsTab_Click"/>
              </StackPanel> -->

              <Border Grid.Row="2" Grid.Column="0" Background="#1E2127" BorderBrush="#343949" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,24,0">
                <StackPanel Spacing="16">
                  <TextBlock x:Name="DetailBodyTitle" FontSize="20" FontWeight="Bold"/>
                  <TextBlock x:Name="DetailBodyText" TextWrapping="Wrap" FontSize="14" LineHeight="22"/>
                </StackPanel>
              </Border>

              <StackPanel Grid.Row="2" Grid.Column="1" Spacing="16">
                <Border Background="#1E2127" BorderBrush="#343949" BorderThickness="1" CornerRadius="12" Padding="16">
                  <StackPanel Spacing="16">
                    <Button x:Name="DetailInstallButton"
                            Background="#00D084"
                            Foreground="#FFFFFF"
                            Height="48"
                            FontSize="15"
                            FontWeight="SemiBold"
                            CornerRadius="8"
                            Click="DetailInstallButton_Click">
                      <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="Install" VerticalAlignment="Center"/>
                      </StackPanel>
                    </Button>

                    <TextBlock x:Name="DetailTargetText"
                               Classes="epicMuted"
                               FontSize="12"
                               TextWrapping="Wrap"/>

                    <StackPanel Spacing="8">
                      <TextBlock Text="Minecraft Version" FontSize="12" Classes="epicMuted"/>
                      <ComboBox x:Name="DetailVersionCombo" Height="40" SelectionChanged="DetailVersionCombo_SelectionChanged"/>
                    </StackPanel>

                    <StackPanel x:Name="DetailLoaderPanel" Spacing="8">
                      <TextBlock Text="Loader" FontSize="12" Classes="epicMuted"/>
                      <ComboBox x:Name="DetailLoaderCombo" Height="40" SelectionChanged="DetailLoaderCombo_SelectionChanged"/>
                    </StackPanel>

                    <ProgressBar x:Name="DetailInstallProgress" Height="4" IsVisible="False" Margin="0,4,0,0"/>
                    <TextBlock x:Name="DetailRequirementText" Classes="epicCaption" TextWrapping="Wrap"/>
                    <TextBlock x:Name="DetailInstallStatus" Classes="epicCaption" TextWrapping="Wrap"/>
                  </StackPanel>
                </Border>

                <Border Background="#1E2127" BorderBrush="#343949" BorderThickness="1" CornerRadius="12" Padding="16">
                  <StackPanel Spacing="12">
                    <TextBlock Text="Compatibility" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock Text="Minecraft: Java Edition" FontSize="13" Classes="epicMuted" Margin="0,4,0,0"/>
                    <WrapPanel x:Name="DetailVersionTags" Margin="0,4,0,0"/>
                    <TextBlock Text="Platforms" FontSize="13" Classes="epicMuted" Margin="0,8,0,0"/>
                    <WrapPanel x:Name="DetailPlatformTags" Margin="0,4,0,0"/>
                    <TextBlock Text="Supported environments" FontSize="13" Classes="epicMuted" Margin="0,8,0,0"/>
                    <WrapPanel x:Name="DetailEnvironmentTags" Margin="0,4,0,0">
                      <Border Background="#343949" CornerRadius="4" Padding="8,4" Margin="0,0,6,4">
                        <TextBlock Text="Client-side" FontSize="12"/>
                      </Border>
                      <Border Background="#343949" CornerRadius="4" Padding="8,4" Margin="0,0,6,4">
                        <TextBlock Text="Server-side" FontSize="12"/>
                      </Border>
                    </WrapPanel>
                  </StackPanel>
                </Border>

                <Border Background="#1E2127" BorderBrush="#343949" BorderThickness="1" CornerRadius="12" Padding="16">
                  <StackPanel Spacing="12">
                    <TextBlock Text="Links" FontSize="16" FontWeight="SemiBold"/>
                    <StackPanel Spacing="8">
                      <TextBlock x:Name="DetailLinkProject" Classes="epicMuted" FontSize="13" Cursor="Hand" PointerPressed="DetailLinkProject_PointerPressed"/>
                    </StackPanel>
                  </StackPanel>
                </Border>

                <Border Background="#1E2127" BorderBrush="#343949" BorderThickness="1" CornerRadius="12" Padding="16">
                  <StackPanel Spacing="12">
                    <TextBlock Text="Tags" FontSize="16" FontWeight="SemiBold"/>
                    <WrapPanel x:Name="DetailTagsPanel" Margin="0,4,0,0"/>
                  </StackPanel>
                </Border>
              </StackPanel>
            </Grid>
          </ScrollViewer>
        </Grid>
      </Border>
    </Grid>
  </Border>
  </Grid>
</Window>
