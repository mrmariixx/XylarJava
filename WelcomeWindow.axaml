<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="XylarJavaLauncher.WelcomeWindow"
        x:CompileBindings="False"
        Title="Welcome to XylarJava"
        Width="920"
        Height="620"
        MinWidth="860"
        MinHeight="580"
        WindowStartupLocation="CenterScreen"
        Background="#08080A"
        CanResize="False"
        ShowInTaskbar="False">

  <Window.Styles>
    <Style Selector="Window">
      <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, Arial"/>
    </Style>

    <Style Selector="TextBlock">
      <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="TextBlock.muted">
      <Setter Property="Foreground" Value="#A2A2AA"/>
    </Style>

    <Style Selector="TextBox.welcomeInput">
      <Setter Property="Background" Value="#15161B"/>
      <Setter Property="Foreground" Value="#FFFFFF"/>
      <Setter Property="BorderBrush" Value="#2F3038"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="14"/>
      <Setter Property="Height" Value="46"/>
      <Setter Property="Padding" Value="16,0"/>
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
    </Style>

    <Style Selector="Button.microsoftPrimary">
      <Setter Property="Background" Value="#F5F5F7"/>
      <Setter Property="Foreground" Value="#111217"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="15"/>
      <Setter Property="Height" Value="48"/>
      <Setter Property="CornerRadius" Value="14"/>
      <Setter Property="BorderBrush" Value="#373843"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="18,0"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>

    <Style Selector="Button.microsoftPrimary:pointerover">
      <Setter Property="Background" Value="#FFFFFF"/>
      <Setter Property="BorderBrush" Value="#4A4B57"/>
    </Style>

    <Style Selector="Button.microsoftPrimary:pressed">
      <Setter Property="Background" Value="#ECECEF"/>
    </Style>

    <Style Selector="Button.welcomeSecondary">
      <Setter Property="Background" Value="#17181D"/>
      <Setter Property="Foreground" Value="#FFFFFF"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="15"/>
      <Setter Property="Height" Value="46"/>
      <Setter Property="CornerRadius" Value="14"/>
      <Setter Property="BorderBrush" Value="#34353E"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="18,0"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>

    <Style Selector="Button.welcomeSecondary:pointerover">
      <Setter Property="Background" Value="#1E2027"/>
    </Style>

    <Style Selector="Button.welcomePrimary">
      <Setter Property="Background" Value="#F5F5F7"/>
      <Setter Property="Foreground" Value="#111217"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="15"/>
      <Setter Property="Height" Value="48"/>
      <Setter Property="CornerRadius" Value="14"/>
      <Setter Property="BorderBrush" Value="#373843"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="18,0"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>
  </Window.Styles>

  <Grid ClipToBounds="True">
    <Ellipse Width="560"
             Height="560"
             HorizontalAlignment="Left"
             VerticalAlignment="Top"
             Margin="-140,-120,0,0"
             Opacity="0.82">
      <Ellipse.Fill>
        <RadialGradientBrush RadiusX="78%" RadiusY="78%">
          <GradientStop Color="#26272F" Offset="0.1"/>
          <GradientStop Color="#0026272F" Offset="1"/>
        </RadialGradientBrush>
      </Ellipse.Fill>
    </Ellipse>

    <Ellipse Width="760"
             Height="760"
             HorizontalAlignment="Right"
             VerticalAlignment="Top"
             Margin="0,-260,-140,0"
             Opacity="0.7">
      <Ellipse.Fill>
        <RadialGradientBrush RadiusX="82%" RadiusY="82%">
          <GradientStop Color="#2E2E36" Offset="0.15"/>
          <GradientStop Color="#002E2E36" Offset="1"/>
        </RadialGradientBrush>
      </Ellipse.Fill>
    </Ellipse>

    <Ellipse Width="520"
             Height="520"
             HorizontalAlignment="Center"
             VerticalAlignment="Bottom"
             Margin="0,0,160,-180"
             Opacity="0.72">
      <Ellipse.Fill>
        <RadialGradientBrush RadiusX="80%" RadiusY="80%">
          <GradientStop Color="#202127" Offset="0.12"/>
          <GradientStop Color="#00202127" Offset="1"/>
        </RadialGradientBrush>
      </Ellipse.Fill>
    </Ellipse>

    <Border x:Name="StagePanel"
            Width="500"
            Padding="44,40"
            CornerRadius="28"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="#101115"
            BorderBrush="#2F3038"
            BorderThickness="1.5"
            Opacity="0">
      <Grid>
        <StackPanel x:Name="IntroPanel"
                    Spacing="18"
                    HorizontalAlignment="Center">
          <TextBlock Text="Hi! Welcome to XylarJava!"
                     MaxWidth="380"
                     FontSize="42"
                     FontWeight="SemiBold"
                     TextAlignment="Center"
                     TextWrapping="Wrap"/>

          <TextBlock Text="Choose your account setup."
                      Classes="muted"
                     MaxWidth="360"
                     FontSize="15"
                     TextAlignment="Center"
                     TextWrapping="Wrap"/>

          <StackPanel Spacing="12"
                      Width="310"
                      HorizontalAlignment="Center">
            <Button x:Name="MicrosoftSignInButton"
                    Classes="microsoftPrimary"
                    Width="290"
                    Click="MicrosoftSignInButton_Click">
              <StackPanel Orientation="Horizontal"
                          Spacing="12"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Center">
                <Grid Width="18"
                      Height="18"
                      ColumnDefinitions="*,*"
                      RowDefinitions="*,*">
                  <Border Grid.Row="0" Grid.Column="0" Background="#F35325" Margin="0,0,1,1"/>
                  <Border Grid.Row="0" Grid.Column="1" Background="#81BC06" Margin="1,0,0,1"/>
                  <Border Grid.Row="1" Grid.Column="0" Background="#05A6F0" Margin="0,1,1,0"/>
                  <Border Grid.Row="1" Grid.Column="1" Background="#FFBA08" Margin="1,1,0,0"/>
                </Grid>
                <TextBlock Text="Sign in with Microsoft"
                           Foreground="#06111B"
                           FontSize="15"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <Button x:Name="GoOfflineButton"
                    Classes="welcomeSecondary"
                    Width="290"
                    Content="Go offline"
                    Click="GoOfflineButton_Click"/>
          </StackPanel>
        </StackPanel>

        <StackPanel x:Name="OfflineNamePanel"
                    IsVisible="False"
                    Opacity="0"
                    Spacing="18"
                    HorizontalAlignment="Center">
          <TextBlock Text="Choose a launch name"
                     MaxWidth="380"
                     FontSize="34"
                     FontWeight="SemiBold"
                     TextAlignment="Center"
                     TextWrapping="Wrap"/>

          <TextBlock Text="Set the name used by your offline profile."
                     Classes="muted"
                     MaxWidth="340"
                     FontSize="14"
                     TextAlignment="Center"
                     TextWrapping="Wrap"/>

          <TextBox x:Name="OfflineUsernameBox"
                   Classes="welcomeInput"
                   Width="290"
                   Watermark="Launch name"/>

          <StackPanel Spacing="12"
                      Width="310"
                      HorizontalAlignment="Center">
            <Button x:Name="ContinueOfflineButton"
                    Classes="welcomePrimary"
                    Width="290"
                    Content="Continue offline"
                    Click="ContinueOfflineButton_Click"/>

            <Button x:Name="BackToChoiceButton"
                    Classes="welcomeSecondary"
                    Width="290"
                    Content="Back"
                    Click="BackToChoiceButton_Click"/>
          </StackPanel>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
